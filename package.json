{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node tests/startup-config.test.js && node tests/integration.server.test.js && node tests/store.test.js && node tests/pieces.test.js",
    "build": "pkg server.js --target node18-win-x64 --output whatsapp-bot.exe",
    "build:server-runtime": "node desktop/build-server-runtime.js",
    "build:desktop-package": "node desktop/build-package.js",
    "validate:release-artifacts": "node scripts/validate_release_artifacts.js --require-package",
    "release:check": "npm test && node desktop/build-server-runtime.js && node desktop/build-package.js && node scripts/validate_release_artifacts.js --require-package",
    "migrate:mssql": "node scripts/migrate_sqlite_to_mssql.js",
    "demo:seed": "node scripts/demo_seed.js --apply",
    "demo:restore": "node scripts/demo_restore.js --latest --apply"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "mssql": "^10.0.1",
    "pino": "^10.3.0",
    "puppeteer": "^24.35.0",
    "qrcode": "^1.5.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "github:jasonfish568/whatsapp-web.js#a9287a2d58bc7c953b608b1198603e36bfa6879e",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  }
}
