# Laser Control runtime config
# Desktop: al primer inicio se copia a %LOCALAPPDATA%\LaserControl\server.env
# Dev/CLI: puedes copiar este archivo a .env o exportar LASERCONTROL_ENV_PATH apuntando a server.env

PORT=3000
HOST=0.0.0.0

AUTH_ENABLED=true
AUTH_REQUIRE_PASSWORD=false
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=__GENERATE_ADMIN_PASSWORD__
AUTH_SECRET=__GENERATE_AUTH_SECRET__

# Protege cierres mensuales y resets operativos.
RESET_PASSWORD=__GENERATE_RESET_PASSWORD__

# Persistencia
WRITE_TO_ENGRAVE_FILES=false
# AUTH_COOKIE_SECURE=true
# USE_MSSQL=false
# MSSQL_SERVER=
# MSSQL_DATABASE=
# MSSQL_USER=
# MSSQL_PASSWORD=

# Rutas opcionales
# LASER_DB_PATH=
# TO_ENGRAVE_DIR=
# ALLOWED_GROUPS_FILE=
# LASER_BACKUP_DIR=
# LASER_BACKUP_KEEP_COUNT=30
# LASER_LOG_DIR=
